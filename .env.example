# ===========================================
# FormFlow — variáveis de ambiente
# Copie para .env e ajuste. Com Docker: use os valores abaixo.
# ===========================================

# Banco (obrigatório). Com docker compose: postgres + redis já expostos em localhost.
DATABASE_URL="postgresql://formflow:formflow@localhost:5432/formflow"

# Redis (opcional; cache de resolução de tenant). Com docker compose: redis em 6379.
REDIS_URL="redis://localhost:6379"

# URL do app (usada para subdomínios e links). Dev: localhost:3000.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Dev: tenant padrão ao acessar localhost (evita 404). UUID fixo do seed (tenant-a).
DEV_TENANT_ID="aaaaaaaa-bbbb-4ccc-dddd-eeeeeeeeeeee"
DEV_TENANT_SLUG="tenant-a"

# --- Opcional: provisionamento de subdomínio (Vercel)
# VERCEL_TOKEN=""
# VERCEL_PROJECT_ID=""
# VERCEL_TEAM_ID=""
