# Banco (obrigatório para rodar app e migrações)
DATABASE_URL="postgresql://user:password@localhost:5432/formflow"

# Redis (opcional; usado para cache de resolução de tenant no middleware)
REDIS_URL="redis://localhost:6379"

# App URL (opcional; usado para extrair slug do subdomínio)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Dev: tenant padrão quando acessar localhost (evita 404 sem Redis)
DEV_TENANT_ID="uuid-do-tenant-de-dev"
DEV_TENANT_SLUG="tenant-a"
